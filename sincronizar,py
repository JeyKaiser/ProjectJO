    ws.cell(row=ultima_fila, column=2, value=fila[1])   # Cod_Material
    ws.cell(row=ultima_fila, column=16, value=fila[3])  # Consumo_Creativo (col P)
    # ... etc

# 6. Guardar
wb.save("prueba3.xlsx")
print("Sincronización completada")